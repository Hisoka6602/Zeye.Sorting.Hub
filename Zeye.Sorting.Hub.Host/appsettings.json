{
  // 持久化总配置（数据库提供器、分表起始时间、性能参数、自动调优参数）
  "Persistence": {
    // 数据库提供器：MySql 或 SqlServer
    "Provider": "MySql",
    // 分片/分表参数配置
    "Sharding": {
      // Parcel 分表起始时间（本地时间语义，不允许 Z 或时区偏移）
      "ParcelStartTime": "2026-01-01T00:00:00"
    },
    // 数据库执行性能与瞬时故障重试参数
    "PerformanceTuning": {
      // 数据库命令超时时间（秒）
      "CommandTimeoutSeconds": 30,
      // 识别慢命令的最小耗时阈值（毫秒）
      "MinCommandElapsedMilliseconds": 50,
      // 瞬时故障最大重试次数
      "MaxRetryCount": 5,
      // 单次重试最大退避延迟（秒）
      "MaxRetryDelaySeconds": 10
    },
    // 慢查询采集、分析与告警基线参数（当前 L1 仅输出观测与建议，不自动执行 DDL/重操作）
    "AutoTuning": {
      // 进入自动调优分析的慢查询阈值（毫秒）
      "SlowQueryThresholdMilliseconds": 500,
      // 每轮分析的慢查询样本批次大小
      "AnalysisBatchSize": 20,
      // 同类慢查询触发分析结论所需最小出现次数
      "TriggerCount": 3,
      // 每个分析周期可生成的建议动作上限
      "MaxActionsPerCycle": 3,
      // 慢查询采集队列最大长度（超限后按策略丢弃）
      "MaxQueueSize": 1000,
      // 后台自动分析执行间隔（秒）
      "AnalyzeIntervalSeconds": 30,
      // 聚合输出 TopN 慢查询指纹数量
      "AggregationTopN": 10,
      // 告警基础防抖：同一 SQL 指纹最小调用次数（低于该值不触发阈值告警）
      "AlertDebounceMinCallCount": 3,
      // P99 延迟告警阈值（毫秒）
      "AlertP99Milliseconds": 500,
      // 超时率告警阈值（百分比）
      "AlertTimeoutRatePercent": 1,
      // 死锁告警阈值（周期内最小次数）
      "AlertDeadlockCount": 1,
      // 日报生成时间（本地时间，建议使用 HH:mm:ss 形式）
      "DailyReportLocalTime": "02:30:00",
      // 基线命令超时时间（秒），用于审计 PerformanceTuning 配置是否偏离推荐值
      "BaselineCommandTimeoutSeconds": 30,
      // 基线最大重试次数，用于审计 PerformanceTuning 配置是否偏离推荐值
      "BaselineMaxRetryCount": 5,
      // 基线最大重试延迟（秒），用于审计 PerformanceTuning 配置是否偏离推荐值
      "BaselineMaxRetryDelaySeconds": 10,
      // L2：半自动调优策略（自动给动作并可控执行）
      "L2": {
        // 是否启用自动动作执行（false 时仅采集、分析与输出建议）
        "EnableActionExecution": false,
        // 是否启用危险动作隔离器（CREATE/ALTER/DROP 默认仅 dry-run）
        "EnableDangerousActionIsolator": true,
        // 是否启用 dry-run（true 时不落库执行，只输出审计与回滚脚本）
        "EnableDryRun": true,
        // 每个分析周期最多执行动作条数（防止集中变更）
        "MaxExecuteActionsPerCycle": 2,
        // 自动动作执行超时（秒）
        "ActionExecutionTimeoutSeconds": 60,
        // 高峰时段是否禁止变更（高峰仅采集分析，不执行动作）
        "SkipExecutionDuringPeak": true,
        // 高峰起始时间（本地时间）
        "PeakStartLocalTime": "08:00:00",
        // 高峰结束时间（本地时间）
        "PeakEndLocalTime": "21:00:00",
        // P99 环比增长告警阈值（百分比，触发计划回退告警；0 表示关闭该项判定）
        "RegressionP99IncreasePercent": 30,
        // 超时率环比增长告警阈值（百分比；0 表示关闭该项判定）
        "RegressionTimeoutRateIncreasePercent": 1,
        // 是否允许在检测到回退后自动执行回滚脚本
        "EnableAutoRollback": true,
        // 允许自动动作的白名单表（支持 table 或 schema.table；为空时阻止所有表执行自动动作）
        "WhitelistedTables": [
          "parcels",
          "dbo.parcels"
        ]
      }
    }
  },
  // 数据库连接字符串配置（使用占位符，禁止提交真实凭据）
  "ConnectionStrings": {
    // MySQL 连接字符串
    "MySql": "server=127.0.0.1;port=3306;database=zeye_sorting_hub;uid={MYSQL_USER};pwd={MYSQL_PASSWORD};SslMode=None;",
    // SQL Server 连接字符串
    "SqlServer": "Server=127.0.0.1,1433;Database=zeye_sorting_hub;User Id={SQLSERVER_USER};Password={SQLSERVER_PASSWORD};TrustServerCertificate=True;Encrypt=False;"
  },
  // 日志配置
  "Logging": {
    // 按日志分类配置最低输出级别
    "LogLevel": {
      // 应用默认日志级别
      "Default": "Information",
      // Host 生命周期日志级别
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
