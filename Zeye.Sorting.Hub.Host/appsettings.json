{
  "Persistence": {
    "Provider": "MySql",
    "Sharding": {
      "ParcelStartTime": "2026-01-01T00:00:00"
    },
    "PerformanceTuning": {
      "CommandTimeoutSeconds": 30,
      "MinCommandElapsedMilliseconds": 50
    },
    "AutoTuning": {
      "SlowQueryThresholdMilliseconds": 500,
      "AnalysisBatchSize": 20,
      "TriggerCount": 3,
      "MaxActionsPerCycle": 3,
      "AnalyzeIntervalSeconds": 30
    }
  },
  "ConnectionStrings": {
    "MySql": "server=127.0.0.1;port=3306;database=zeye_sorting_hub;uid={MYSQL_USER};pwd={MYSQL_PASSWORD};SslMode=None;",
    "SqlServer": "Server=127.0.0.1,1433;Database=zeye_sorting_hub;User Id={SQLSERVER_USER};Password={SQLSERVER_PASSWORD};TrustServerCertificate=True;Encrypt=False;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
